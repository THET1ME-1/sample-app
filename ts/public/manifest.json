{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "VisionWatch",
    "author": "VisionWatch Team",
    "version": "1.0.0",
    "minimum-overwolf-version": "0.160.0",
    "description": "Overwatch companion app: real-time overlay, hero recommendations, counter picks and match statistics.",
    "dock_button_title": "VisionWatch",
    "icon": "icons/IconMouseOver.png",
    "icon_gray": "icons/IconMouseNormal.png",
    "launcher_icon": "icons/desktop-icon.ico",
    "window_icon": "icons/IconMouseOver.png"
  },
  "permissions": [
    "Hotkeys",
    "GameInfo",
    "Extensions"
  ],
  "data": {
    "start_window": "background",
    "hotkeys": {
      "vw_toggle_overlay": {
        "title": "Show/Hide Overlay",
        "action-type": "toggle",
        "default": "Ctrl+Shift+Z"
      }
    },
    "protocol_override_domains": {
      "googlesyndication": "http"
    },
    "externally_connectable": {
      "matches": [
        "http://*.overwolf.com",
        "https://*.overwolf.com"
      ]
    },
    "force_browser": "user",
    "windows": {
      "background": {
        "file": "background.html",
        "background_optimization": true,
        "is_background_page": true
      },
      "desktop": {
        "file": "desktop.html",
        "desktop_only": true,
        "native_window": true,
        "resizable": true,
        "transparent": true,
        "override_on_update": true,
        "size": {
          "width": 1200,
          "height": 720
        },
        "min_size": {
          "width": 900,
          "height": 600
        }
      },
      "in_game": {
        "file": "in_game.html",
        "in_game_only": true,
        "focus_game_takeover": "ReleaseOnHidden",
        "focus_game_takeover_release_hotkey": "vw_toggle_overlay",
        "resizable": true,
        "transparent": true,
        "override_on_update": true,
        "size": {
          "width": 460,
          "height": 680
        },
        "min_size": {
          "width": 340,
          "height": 500
        }
      }
    },
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [10844]
    },
    "game_events": [10844],
    "launch_events": [
      {
        "event": "GameLaunch",
        "event_data": {
          "game_ids": [10844]
        },
        "start_minimized": true
      }
    ],
    "developer": {
      "enable_auto_refresh": true,
      "reload_delay": 1000,
      "filter": "*.*"
    }
  }
}
